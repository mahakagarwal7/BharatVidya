    {
      "id": "text_0",
      "type": "text",
      "description": "A linked list is a linear collection of data elements, called nodes.",
      "x": 80,
      "y": 450
    },
    {
      "id": "text_1",
      "type": "text",
      "description": "Each node contains two items \u2013 the data and a reference (or link) to the next node in the sequence.",
      "x": 80,
      "y": 480
    },
    {
      "id": "text_2",
      "type": "text",
      "description": "Unlike arrays, links between elements are not contiguous, but instead point from one element to another anywhere within or outside the list structure.",
      "x": 80,
      "y": 510
    },
    {
      "id": "text_3",
      "type": "text",
      "description": "Linked lists allow for efficient insertion or removal of elements without reorganizing the entire data set.",
      "x": 80,
      "y": 540
